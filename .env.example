# ─────────────────────────────────────────────────────────────────────────────
# BetIQ — Environment configuration template
# Copy to `.env` and adjust values for your deployment.
# ─────────────────────────────────────────────────────────────────────────────

# Database URL.
# Local dev (SQLite): file:/app/db/custom.db
# Production (PostgreSQL): postgresql://user:password@host:5432/betiq?schema=public
DATABASE_URL=file:/app/db/custom.db

# Timezone for date bucketing & scheduler. Default: Europe/Brussels.
TZ=Europe/Brussels

# Disable the daily 00:00 scheduler (useful for one-off pipeline runs).
# DISABLE_SCHEDULER=true

# HTTP server port (defaults to 3000).
PORT=3000

# Node environment.
NODE_ENV=production

# ─────────────────────────────────────────────────────────────────────────────
# Optional: source enable flags (1 = enabled, 0 = disabled)
# ─────────────────────────────────────────────────────────────────────────────
ENABLE_ESPN=1
ENABLE_PREDICTZ=1
ENABLE_WINDRAWWIN=1
ENABLE_STATAREA=1

# ─────────────────────────────────────────────────────────────────────────────
# D2: Reliable API-based prediction sources (free tiers, real JSON APIs)
# ─────────────────────────────────────────────────────────────────────────────
# These don't depend on HTML scraping, so they actually work reliably.
# Both have free tiers — sign up and paste your API key here.
#
# football-data.org — Free tier: 10 req/sec, real fixtures for top 5 leagues + UCL
#   Sign up: https://www.football-data.org/client/register
FOOTBALL_DATA_API_TOKEN=

# the-odds-api — Free tier: 500 req/month, real bookmaker odds (multi-book)
#   Sign up: https://the-odds-api.com/liveapi/guides/v4/
THE_ODDS_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Owner authentication — protects the "Won Parlays History" owner-private view.
# ─────────────────────────────────────────────────────────────────────────────
# Set a long random token here. ONCE per browser, visit:
#
#   https://your-site.com/api/owner/unlock?token=YOUR_TOKEN
#
# The server sets a 10-year HTTP-only signed cookie (`betiq_owner`). After that
# the "Won History" tab auto-renders on every visit — no password modal, no
# login button, same UX as the Performance tab being visible only to you.
#
# Non-owner visitors never see the tab, never fire the gated fetch, and the
# API returns 404 (no leak that the endpoint exists).
#
# In production this MUST be set — without it, owner unlock is disabled
# entirely (the dev-only fallback token "owner" is rejected when
# NODE_ENV=production).
#
# To clear the cookie on a shared device, visit: /api/owner/lock
#
# Optional: SITE_OWNER_COOKIE_SECRET (>=16 chars) signs the cookie. When
# omitted, falls back to SITE_OWNER_TOKEN (if it's >=16 chars). Only set this
# if you want to rotate the cookie secret independently of the unlock token.
SITE_OWNER_TOKEN=
# SITE_OWNER_COOKIE_SECRET=
