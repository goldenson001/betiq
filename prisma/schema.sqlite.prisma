// Football Predictions Platform — Prisma Schema (SQLite)
// Used in local dev when DATABASE_URL starts with "file:".
// Auto-selected by scripts/select-schema.mjs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────────────────────
// Sources — each prediction scraper site is a Source with a tracked accuracy.
// ──────────────────────────────────────────────────────────────────────────────
model Source {
  id            String   @id @default(cuid())
  name          String   @unique
  displayName   String
  url           String
  weight        Float    @default(0.5)
  totalPredictions  Int    @default(0)
  correctPredictions Int   @default(0)
  accuracy      Float    @default(0)
  roi           Float    @default(0)
  calibration   Float    @default(0.5)
  calibrationA  Float    @default(1)
  calibrationB  Float    @default(0)
  calibrationN  Int      @default(0)
  calibrationJson String?
  // ── Rolling reliability metrics ───────────────────────────────────────────
  // Trailing Brier score (lower = better) and CLV (positive = beats closing
  // line). Updated by the feedback loop after each match day. Used by the
  // engine to weight sources: bad recent form → downweight.
  brier30d      Float    @default(0.25)
  clv30d        Float    @default(0)
  recentSamples Int      @default(0)
  lastScrapedAt DateTime?
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  predictions RawPrediction[]
  leagueCalibrations SourceLeagueCalibration[]
}

// ──────────────────────────────────────────────────────────────────────────────
// Per-league calibration — each source can be well-calibrated on the Premier
// League but poorly calibrated on Serie B. This table stores separate Platt
// params for each (source, league) pair, fitted from samples collected in
// the feedback loop.
// ──────────────────────────────────────────────────────────────────────────────
model SourceLeagueCalibration {
  id          String   @id @default(cuid())
  sourceId    String
  source      Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  leagueId    String
  league      League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  // Platt params — identity (a=1, b=0) until enough samples accumulate.
  calibrationA Float   @default(1)
  calibrationB Float   @default(0)
  sampleCount  Int     @default(0)
  samplesJson  String?
  lastUpdated  DateTime @updatedAt

  @@unique([sourceId, leagueId])
  @@index([leagueId])
}

// ──────────────────────────────────────────────────────────────────────────────
// Per-(market, league) rolling CLV — used by B3 (CLV gate for safest tier +
// safe-high-odds picks). If the engine systematically loses to the closing
// line on a particular (market, league) combo (e.g. corners_ou in Premier
// League), picks on that combo are EXCLUDED from investment-grade tiers.
// ──────────────────────────────────────────────────────────────────────────────
model MarketLeagueClv {
  id          String   @id @default(cuid())
  market      String
  leagueId    String   @default("none")
  // Rolling 30-day mean CLV across all predictions on this (market, league).
  // Positive = beats closing line (good). Negative = loses to closing line.
  avgClv      Float    @default(0)
  sampleCount Int      @default(0)
  samplesJson String?  // Array of recent CLV samples for recompute
  lastUpdated DateTime @updatedAt

  @@unique([market, leagueId])
  @@index([market])
  @@index([leagueId])
}

// ──────────────────────────────────────────────────────────────────────────────
// Elo team-strength ratings (A2). Updated after every finished match.
// Used as a bookmaker-independent prior for 1X2 prediction in low-coverage
// matches (lower leagues, cup games, early season).
// ──────────────────────────────────────────────────────────────────────────────
model TeamRating {
  id          String   @id @default(cuid())
  teamName    String
  leagueId    String   @default("none")
  // Elo rating — typical range 1200-2200, mean ~1500.
  rating      Float    @default(1500)
  // Number of matches the rating is based on (for confidence).
  matches     Int      @default(0)
  // Last-5 form derived from Elo updates (W/D/L string).
  form        String?
  lastUpdated DateTime @updatedAt

  @@unique([teamName, leagueId])
  @@index([teamName])
  @@index([leagueId])
}

model League {
  id        String   @id @default(cuid())
  name      String   @unique
  country   String
  code      String?
  createdAt DateTime @default(now())
  matches   Match[]
  sourceCalibrations SourceLeagueCalibration[]
}

model Team {
  id        String   @id @default(cuid())
  name      String   @unique
  aliases   String
  createdAt DateTime @default(now())
}

model Match {
  id          String    @id @default(cuid())
  externalId  String    @unique
  matchDate   String
  kickoffUtc  DateTime
  kickoffBrussels String
  leagueId    String?
  league      League?   @relation(fields: [leagueId], references: [id])
  homeTeam    String
  awayTeam    String
  homeTeamId  String?
  awayTeamId  String?
  status      String    @default("scheduled")
  homeScore   Int?
  awayScore   Int?
  htHomeScore Int?
  htAwayScore Int?
  corners     Int?
  cards       Int?
  oddsJson    String?
  openingOddsJson String?
  closingOddsJson String?
  // ── D1: Mid-week odds snapshots for steam-move detection ──────────────────
  // Array of { capturedAt, oddsJson } snapshots. Updated by a mid-day
  // scheduler job so we can detect line movement between open and close.
  oddsSnapshotsJson String?
  clvComputed     Boolean  @default(false)
  h2hJson     String?
  // ── A3: Home/away-split form + rest days ──────────────────────────────────
  // homeForm/awayForm are the existing last-5 overall form strings. New fields
  // split by venue + track rest days for fixture-congestion penalty.
  homeForm    String?
  awayForm    String?
  homeVenueForm String?
  awayVenueForm String?
  restDaysHome  Int?
  restDaysAway  Int?
  resultProcessed Boolean @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  rawPredictions RawPrediction[]
  predictions    Prediction[]
  @@index([matchDate])
  @@index([kickoffUtc])
  @@index([status])
}

model RawPrediction {
  id          String   @id @default(cuid())
  matchId     String
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sourceId    String
  source      Source   @relation(fields: [sourceId], references: [id])
  payloadJson String
  predicted1X2    String?
  predictedScore  String?
  predictedBTTS   String?
  predictedOU25   String?
  evaluated   Boolean  @default(false)
  correct     Boolean?
  createdAt   DateTime @default(now())

  @@index([matchId, sourceId])
}

model Prediction {
  id          String   @id @default(cuid())
  matchId     String
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  market      String
  selection   String
  confidence  Float
  probability Float
  fairOdds    Float
  bookOdds    Float?
  edge        Float?
  isTopPick   Boolean  @default(false)
  isValueBet  Boolean  @default(false)
  isSafePick      Boolean  @default(false)
  isSafeHighOdds   Boolean  @default(false)
  consensusSources Int     @default(0)
  // ── C2: Source disagreement — stdev of per-source probabilities for this pick ──
  // Low = sources agree (reliable), high = sources disagree (lottery).
  // Used by safe-high-odds filter to exclude high-disagreement picks.
  disagreement Float?
  kellyFraction   Float?
  recommendedStake Float?
  clv             Float?
  sourcesJson String?
  evaluated   Boolean  @default(false)
  correct     Boolean?
  createdAt   DateTime @default(now())

  @@index([matchId, market])
  @@index([confidence])
  @@index([isValueBet])
  @@index([isTopPick])
  @@index([isSafePick])
  @@index([isSafeHighOdds])
}

model Parlay {
  id          String   @id @default(cuid())
  matchDate   String
  type        String
  legsJson    String
  legsCount   Int
  combinedProbability Float
  combinedOdds Float
  confidence  Float
  expectedValue Float
  kellyFraction   Float?
  recommendedStake Float?
  evaluated   Boolean  @default(false)
  won         Boolean?
  // ── ML-driven parlay selection signals ─────────────────────────────────────
  mlScore         Float?
  mlComponentsJson String?
  mlAdjustedProbability Float?
  mlSampleCount   Int?
  createdAt   DateTime @default(now())

  @@index([matchDate, type])
}

// ── ML parlay tier statistics ──────────────────────────────────────────────
// Per-tier (safest, medium_risk, odds_3_a, etc.) rolling stats used by the
// Bayesian shrinkage that adjusts combined probabilities. Updated by the
// feedback loop after each parlay settles.
model ParlayTierStats {
  id          String   @id @default(cuid())
  tier        String   @unique
  totalParlays    Int   @default(0)
  wonParlays      Int   @default(0)
  totalLegs       Int   @default(0)
  wonLegs         Int   @default(0)
  rollingWinRate  Float @default(0)
  lifetimeWinRate Float @default(0)
  recentResultsJson String?
  updatedAt   DateTime @updatedAt
}

model PerformanceSnapshot {
  id          String   @id @default(cuid())
  date        String   @unique
  totalPredictions Int
  correctPredictions Int
  winRate     Float
  roi         Float
  parlaysMade Int
  parlaysWon  Int
  parlayRoi   Float
  winStreak   Int
  loseStreak  Int
  avgClv            Float  @default(0)
  kellyRoi          Float  @default(0)
  calibrationError  Float  @default(0)
  marketBreakdownJson String?
  createdAt   DateTime @default(now())
}

model ModelState {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Float
  notes       String?
  updatedAt   DateTime @updatedAt
}

model ScrapeLog {
  id          String   @id @default(cuid())
  source      String
  startedAt   DateTime
  finishedAt  DateTime?
  matchesFound Int     @default(0)
  predictionsExtracted Int @default(0)
  status      String   @default("running")
  error       String?
  createdAt   DateTime @default(now())
}

// ──────────────────────────────────────────────────────────────────────────────
// REAL-MONEY STAKING LAYER (production-grade accountability)
// ──────────────────────────────────────────────────────────────────────────────
// Three immutable tables that make the system auditable end-to-end:
//
//   PickAudit        — One row per parlay EVER built. Frozen snapshot of every
//                      signal that fed the decision (ML components, H2H score,
//                      Kelly stake, build version, etc.). Even after the parlay
//                      row is wiped on the next pipeline run, the audit row
//                      survives so we can post-mortem losing days.
//
//   StakeLedger      — One row per parlay that carried a positive Kelly stake.
//                      Tracks the lifecycle: recommended → placed → settled.
//                      Settled rows carry actual return + realized ROI so we
//                      can compute bankroll P&L and per-tier realized ROI
//                      (separate from the theoretical combinedProbability).
//
//   BankrollSnapshot — Daily snapshot of bankroll state: current balance, peak,
//                      drawdown %, drawdown state (normal/degraded/halted),
//                      total staked today, total returned today. Used to drive
//                      the risk gate UI and to audit drawdown transitions.
// ──────────────────────────────────────────────────────────────────────────────

model PickAudit {
  id              String   @id @default(cuid())
  // Foreign key to Parlay (kept loose — parlay rows get wiped on re-run, audit
  // rows persist forever).
  parlayId        String
  matchDate       String
  tier            String
  // ── Frozen pick data ────────────────────────────────────────────────────────
  legsJson        String   // snapshot of legs at recommendation time
  legsCount       Int
  combinedProbability Float
  combinedOdds    Float
  // ── ML signals snapshot (what drove the decision) ───────────────────────────
  mlScore         Float?
  mlComponentsJson String? // per-leg reliability + 8-component breakdown
  mlAdjustedProbability Float?
  mlSampleCount   Int?
  // ── H2H snapshot (specifically — user's #1 safety signal) ───────────────────
  h2hSummaryJson  String?  // per-leg H2H agreement scores
  // ── Kelly stake at recommendation time ──────────────────────────────────────
  kellyFraction   Float?
  recommendedStake Float?
  // ── Schema version for forward-compat ───────────────────────────────────────
  schemaVersion   Int      @default(1)
  // ── Settlement (filled by feedback loop when match finishes) ────────────────
  settledAt       DateTime?
  won             Boolean?
  legsWon         Int?
  legsLost        Int?
  legsVoid        Int?
  actualReturn    Float?   // stake × combinedOdds if won, 0 if lost, void rules
  realizedRoi     Float?   // (actualReturn - stake) / stake
  // ── Notes — freeform for manual annotation post-mortem ──────────────────────
  notes           String?
  createdAt       DateTime @default(now())

  @@index([matchDate, tier])
  @@index([parlayId])
  @@index([settledAt])
  @@index([won])
}

model StakeLedger {
  id              String   @id @default(cuid())
  parlayId        String
  pickAuditId     String?  // link to immutable audit record
  matchDate       String
  tier            String
  // ── Stake details ───────────────────────────────────────────────────────────
  recommendedStake Float   // fraction of bankroll [0, 1]
  bankrollAtTime   Float   // bankroll used to compute monetary stake
  stakeAmount      Float   // recommendedStake × bankrollAtTime (monetary)
  combinedOdds     Float
  // ── Lifecycle ───────────────────────────────────────────────────────────────
  // recommended: just computed, not yet placed
  // placed:      user marked as actually bet
  // settled:     match finished, return recorded
  // void:        match voided / postponed / abandoned
  // skipped:     user chose not to place (recorded for compliance audit)
  status          String   @default("recommended")
  placedAt        DateTime?
  settledAt       DateTime?
  // ── Outcome ─────────────────────────────────────────────────────────────────
  won             Boolean?
  actualReturn    Float?   // monetary units returned (0 if lost, stake×odds if won)
  realizedRoi     Float?   // (actualReturn - stakeAmount) / stakeAmount
  // ── Risk context at placement time ──────────────────────────────────────────
  drawdownState   String?  // normal | degraded | halted
  portfolioScale  Float?   // portfolio-cap scale factor applied (1.0 = no scaling)
  // ── Notes ───────────────────────────────────────────────────────────────────
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([matchDate, tier])
  @@index([status])
  @@index([parlayId])
}

model BankrollSnapshot {
  id              String   @id @default(cuid())
  date            String   @unique  // YYYY-MM-DD (Brussels tz)
  // ── Balance ─────────────────────────────────────────────────────────────────
  bankroll        Float              // current bankroll at end of day
  peakBankroll    Float              // all-time peak (for drawdown computation)
  drawdownPct     Float   @default(0) // (peak - current) / peak, capped [0, 1]
  // ── Risk state ──────────────────────────────────────────────────────────────
  drawdownState   String  @default("normal") // normal | degraded | halted
  // ── Today's activity ────────────────────────────────────────────────────────
  totalStaked     Float   @default(0)
  totalReturned   Float   @default(0)
  totalProfit     Float   @default(0)  // totalReturned - totalStaked
  parlaysPlaced   Int     @default(0)
  parlaysWon      Int     @default(0)
  parlaysLost     Int     @default(0)
  parlaysPending  Int     @default(0)
  // ── Streaks (carried forward) ───────────────────────────────────────────────
  winStreak       Int     @default(0)
  loseStreak      Int     @default(0)
  // ── Notes ───────────────────────────────────────────────────────────────────
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
