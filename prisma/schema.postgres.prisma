// Football Predictions Platform — Prisma Schema (PostgreSQL)
// Used in production (Vercel) and any environment where DATABASE_URL
// points at a PostgreSQL database.
// Auto-selected by scripts/select-schema.mjs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────────────────────
// Sources — each prediction scraper site is a Source with a tracked accuracy.
// ──────────────────────────────────────────────────────────────────────────────
model Source {
  id            String   @id @default(cuid())
  name          String   @unique
  displayName   String
  url           String
  weight        Float    @default(0.5)
  totalPredictions  Int    @default(0)
  correctPredictions Int   @default(0)
  accuracy      Float    @default(0)
  roi           Float    @default(0)
  // ── Platt calibration (logistic) ─────────────────────────────────────────
  // P(actual | source says p) = sigmoid(a * p + b)
  // Defaults: a=1, b=0 → identity (no calibration). Fitted in feedback loop.
  calibration   Float    @default(0.5)
  calibrationA  Float    @default(1)
  calibrationB  Float    @default(0)
  calibrationN  Int      @default(0)
  calibrationJson String?
  // ── Rolling reliability metrics ───────────────────────────────────────────
  // Trailing Brier score (lower = better) and CLV (positive = beats closing
  // line). Updated by the feedback loop after each match day. Used by the
  // engine to weight sources: bad recent form → downweight.
  brier30d      Float    @default(0.25)
  clv30d        Float    @default(0)
  recentSamples Int      @default(0)
  lastScrapedAt DateTime?
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  predictions RawPrediction[]
  leagueCalibrations SourceLeagueCalibration[]
}

// ──────────────────────────────────────────────────────────────────────────────
// Per-league calibration — each source can be well-calibrated on the Premier
// League but poorly calibrated on Serie B. This table stores separate Platt
// params for each (source, league) pair, fitted from samples collected in
// the feedback loop.
// ──────────────────────────────────────────────────────────────────────────────
model SourceLeagueCalibration {
  id          String   @id @default(cuid())
  sourceId    String
  source      Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  leagueId    String
  league      League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  // Platt params — identity (a=1, b=0) until enough samples accumulate.
  calibrationA Float   @default(1)
  calibrationB Float   @default(0)
  sampleCount  Int     @default(0)
  samplesJson  String?
  lastUpdated  DateTime @updatedAt

  @@unique([sourceId, leagueId])
  @@index([leagueId])
}

// ──────────────────────────────────────────────────────────────────────────────
// Per-(market, league) rolling CLV — used by B3 (CLV gate for safest tier +
// safe-high-odds picks). If the engine systematically loses to the closing
// line on a particular (market, league) combo (e.g. corners_ou in Premier
// League), picks on that combo are EXCLUDED from investment-grade tiers.
// ──────────────────────────────────────────────────────────────────────────────
model MarketLeagueClv {
  id          String   @id @default(cuid())
  market      String
  leagueId    String   @default("none")
  // Rolling 30-day mean CLV across all predictions on this (market, league).
  // Positive = beats closing line (good). Negative = loses to closing line.
  avgClv      Float    @default(0)
  sampleCount Int      @default(0)
  samplesJson String?  // Array of recent CLV samples for recompute
  lastUpdated DateTime @updatedAt

  @@unique([market, leagueId])
  @@index([market])
  @@index([leagueId])
}

// ──────────────────────────────────────────────────────────────────────────────
// Elo team-strength ratings (A2). Updated after every finished match.
// Used as a bookmaker-independent prior for 1X2 prediction in low-coverage
// matches (lower leagues, cup games, early season).
// ──────────────────────────────────────────────────────────────────────────────
model TeamRating {
  id          String   @id @default(cuid())
  teamName    String
  leagueId    String   @default("none")
  // Elo rating — typical range 1200-2200, mean ~1500.
  rating      Float    @default(1500)
  // Number of matches the rating is based on (for confidence).
  matches     Int      @default(0)
  // Last-5 form derived from Elo updates (W/D/L string).
  form        String?
  lastUpdated DateTime @updatedAt

  @@unique([teamName, leagueId])
  @@index([teamName])
  @@index([leagueId])
}

model League {
  id        String   @id @default(cuid())
  name      String   @unique
  country   String
  code      String?
  createdAt DateTime @default(now())
  matches   Match[]
  sourceCalibrations SourceLeagueCalibration[]
}

model Team {
  id        String   @id @default(cuid())
  name      String   @unique
  aliases   String
  createdAt DateTime @default(now())
}

model Match {
  id          String    @id @default(cuid())
  externalId  String    @unique
  matchDate   String
  kickoffUtc  DateTime
  kickoffBrussels String
  leagueId    String?
  league      League?   @relation(fields: [leagueId], references: [id])
  homeTeam    String
  awayTeam    String
  homeTeamId  String?
  awayTeamId  String?
  status      String    @default("scheduled")
  homeScore   Int?
  awayScore   Int?
  htHomeScore Int?
  htAwayScore Int?
  corners     Int?
  cards       Int?
  oddsJson    String?
  // ── Closing Line Value tracking ──────────────────────────────────────────
  // openingOddsJson: odds snapshot taken when we first predicted the match
  // closingOddsJson: odds snapshot taken just before kickoff (or at feedback)
  // clvComputed:      true once CLV has been computed for this match's top picks
  openingOddsJson String?
  closingOddsJson String?
  // ── D1: Mid-week odds snapshots for steam-move detection ──────────────────
  // Array of { capturedAt, oddsJson } snapshots. Updated by a mid-day
  // scheduler job so we can detect line movement between open and close.
  oddsSnapshotsJson String?
  clvComputed     Boolean  @default(false)
  h2hJson     String?
  // ── A3: Home/away-split form + rest days ──────────────────────────────────
  // homeForm/awayForm are the existing last-5 overall form strings. New fields
  // split by venue + track rest days for fixture-congestion penalty.
  homeForm    String?
  awayForm    String?
  homeVenueForm String?
  awayVenueForm String?
  restDaysHome  Int?
  restDaysAway  Int?
  resultProcessed Boolean @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  rawPredictions RawPrediction[]
  predictions    Prediction[]
  @@index([matchDate])
  @@index([kickoffUtc])
  @@index([status])
}

model RawPrediction {
  id          String   @id @default(cuid())
  matchId     String
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sourceId    String
  source      Source   @relation(fields: [sourceId], references: [id])
  payloadJson String
  predicted1X2    String?
  predictedScore  String?
  predictedBTTS   String?
  predictedOU25   String?
  evaluated   Boolean  @default(false)
  correct     Boolean?
  createdAt   DateTime @default(now())

  @@index([matchId, sourceId])
}

model Prediction {
  id          String   @id @default(cuid())
  matchId     String
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  market      String
  selection   String
  confidence  Float
  probability Float
  fairOdds    Float
  bookOdds    Float?
  edge        Float?
  isTopPick   Boolean  @default(false)
  isValueBet  Boolean  @default(false)
  // ── Safer-pick flag — true when this is the lower-risk side of its market ──
  isSafePick      Boolean  @default(false)
  // ── Safest High-Odds tier — investment-grade picks with odds in 1.50–2.50 ──
  isSafeHighOdds   Boolean  @default(false)
  // ── Consensus strength — number of distinct sources agreeing on this pick ──
  consensusSources Int     @default(0)
  // ── C2: Source disagreement — stdev of per-source probabilities for this pick ──
  // Low = sources agree (reliable), high = sources disagree (lottery).
  // Used by safe-high-odds filter to exclude high-disagreement picks.
  disagreement Float?
  // ── Kelly criterion staking ──────────────────────────────────────────────
  kellyFraction   Float?
  recommendedStake Float?
  // ── Closing Line Value for this individual prediction ─────────────────────
  clv             Float?
  sourcesJson String?
  evaluated   Boolean  @default(false)
  correct     Boolean?
  createdAt   DateTime @default(now())

  @@index([matchId, market])
  @@index([confidence])
  @@index([isValueBet])
  @@index([isTopPick])
  @@index([isSafePick])
  @@index([isSafeHighOdds])
}

model Parlay {
  id          String   @id @default(cuid())
  matchDate   String
  type        String
  legsJson    String
  legsCount   Int
  combinedProbability Float
  combinedOdds Float
  confidence  Float
  expectedValue Float
  // ── Kelly criterion for parlays ──────────────────────────────────────────
  kellyFraction   Float?
  recommendedStake Float?
  evaluated   Boolean  @default(false)
  won         Boolean?
  createdAt   DateTime @default(now())

  @@index([matchDate, type])
}

model PerformanceSnapshot {
  id          String   @id @default(cuid())
  date        String   @unique
  totalPredictions Int
  correctPredictions Int
  winRate     Float
  roi         Float
  parlaysMade Int
  parlaysWon  Int
  parlayRoi   Float
  winStreak   Int
  loseStreak  Int
  // ── Advanced metrics ─────────────────────────────────────────────────────
  // avgClv:       mean CLV across top picks for this date (positive = good)
  // kellyRoi:     ROI from Kelly-sized stakes (vs flat 1u roi above)
  // calibrationError: Brier score (lower = better calibration)
  avgClv            Float  @default(0)
  kellyRoi          Float  @default(0)
  calibrationError  Float  @default(0)
  marketBreakdownJson String?
  createdAt   DateTime @default(now())
}

model ModelState {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Float
  notes       String?
  updatedAt   DateTime @updatedAt
}

model ScrapeLog {
  id          String   @id @default(cuid())
  source      String
  startedAt   DateTime
  finishedAt  DateTime?
  matchesFound Int     @default(0)
  predictionsExtracted Int @default(0)
  status      String   @default("running")
  error       String?
  createdAt   DateTime @default(now())
}
