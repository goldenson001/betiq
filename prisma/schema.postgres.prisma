// Football Predictions Platform — Prisma Schema (PostgreSQL)
// Used in production (Vercel) and any environment where DATABASE_URL
// points at a PostgreSQL database.
// Auto-selected by scripts/select-schema.mjs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────────────────────
// Sources — each prediction scraper site is a Source with a tracked accuracy.
// ──────────────────────────────────────────────────────────────────────────────
model Source {
  id            String   @id @default(cuid())
  name          String   @unique
  displayName   String
  url           String
  weight        Float    @default(0.5)
  totalPredictions  Int    @default(0)
  correctPredictions Int   @default(0)
  accuracy      Float    @default(0)
  roi           Float    @default(0)
  // ── Platt calibration (logistic) ─────────────────────────────────────────
  // P(actual | source says p) = sigmoid(a * p + b)
  // Defaults: a=1, b=0 → identity (no calibration). Fitted in feedback loop.
  calibration   Float    @default(0.5)
  calibrationA  Float    @default(1)
  calibrationB  Float    @default(0)
  calibrationN  Int      @default(0)
  calibrationJson String?
  lastScrapedAt DateTime?
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  predictions RawPrediction[]
}

model League {
  id        String   @id @default(cuid())
  name      String   @unique
  country   String
  code      String?
  createdAt DateTime @default(now())
  matches   Match[]
}

model Team {
  id        String   @id @default(cuid())
  name      String   @unique
  aliases   String
  createdAt DateTime @default(now())
}

model Match {
  id          String    @id @default(cuid())
  externalId  String    @unique
  matchDate   String
  kickoffUtc  DateTime
  kickoffBrussels String
  leagueId    String?
  league      League?   @relation(fields: [leagueId], references: [id])
  homeTeam    String
  awayTeam    String
  homeTeamId  String?
  awayTeamId  String?
  status      String    @default("scheduled")
  homeScore   Int?
  awayScore   Int?
  htHomeScore Int?
  htAwayScore Int?
  corners     Int?
  cards       Int?
  oddsJson    String?
  // ── Closing Line Value tracking ──────────────────────────────────────────
  // openingOddsJson: odds snapshot taken when we first predicted the match
  // closingOddsJson: odds snapshot taken just before kickoff (or at feedback)
  // clvComputed:      true once CLV has been computed for this match's top picks
  openingOddsJson String?
  closingOddsJson String?
  clvComputed     Boolean  @default(false)
  h2hJson     String?
  homeForm    String?
  awayForm    String?
  resultProcessed Boolean @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  rawPredictions RawPrediction[]
  predictions    Prediction[]
  @@index([matchDate])
  @@index([kickoffUtc])
  @@index([status])
}

model RawPrediction {
  id          String   @id @default(cuid())
  matchId     String
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sourceId    String
  source      Source   @relation(fields: [sourceId], references: [id])
  payloadJson String
  predicted1X2    String?
  predictedScore  String?
  predictedBTTS   String?
  predictedOU25   String?
  evaluated   Boolean  @default(false)
  correct     Boolean?
  createdAt   DateTime @default(now())

  @@index([matchId, sourceId])
}

model Prediction {
  id          String   @id @default(cuid())
  matchId     String
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  market      String
  selection   String
  confidence  Float
  probability Float
  fairOdds    Float
  bookOdds    Float?
  edge        Float?
  isTopPick   Boolean  @default(false)
  isValueBet  Boolean  @default(false)
  // ── Kelly criterion staking ──────────────────────────────────────────────
  // kellyFraction:   full Kelly stake (0-1) — fraction of bankroll
  // recommendedStake: fractional Kelly (default 1/4) clamped to [0, 0.05]
  kellyFraction   Float?
  recommendedStake Float?
  // ── Closing Line Value for this individual prediction ─────────────────────
  // (only populated for top picks and value bets)
  clv             Float?
  sourcesJson String?
  evaluated   Boolean  @default(false)
  correct     Boolean?
  createdAt   DateTime @default(now())

  @@index([matchId, market])
  @@index([confidence])
  @@index([isValueBet])
  @@index([isTopPick])
}

model Parlay {
  id          String   @id @default(cuid())
  matchDate   String
  type        String
  legsJson    String
  legsCount   Int
  combinedProbability Float
  combinedOdds Float
  confidence  Float
  expectedValue Float
  // ── Kelly criterion for parlays ──────────────────────────────────────────
  kellyFraction   Float?
  recommendedStake Float?
  evaluated   Boolean  @default(false)
  won         Boolean?
  createdAt   DateTime @default(now())

  @@index([matchDate, type])
}

model PerformanceSnapshot {
  id          String   @id @default(cuid())
  date        String   @unique
  totalPredictions Int
  correctPredictions Int
  winRate     Float
  roi         Float
  parlaysMade Int
  parlaysWon  Int
  parlayRoi   Float
  winStreak   Int
  loseStreak  Int
  // ── Advanced metrics ─────────────────────────────────────────────────────
  // avgClv:       mean CLV across top picks for this date (positive = good)
  // kellyRoi:     ROI from Kelly-sized stakes (vs flat 1u roi above)
  // calibrationError: Brier score (lower = better calibration)
  avgClv            Float  @default(0)
  kellyRoi          Float  @default(0)
  calibrationError  Float  @default(0)
  marketBreakdownJson String?
  createdAt   DateTime @default(now())
}

model ModelState {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Float
  notes       String?
  updatedAt   DateTime @updatedAt
}

model ScrapeLog {
  id          String   @id @default(cuid())
  source      String
  startedAt   DateTime
  finishedAt  DateTime?
  matchesFound Int     @default(0)
  predictionsExtracted Int @default(0)
  status      String   @default("running")
  error       String?
  createdAt   DateTime @default(now())
}
